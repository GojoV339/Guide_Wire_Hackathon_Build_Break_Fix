DATABASE_URL=sqlite:///./gigshield.db
SECRET_KEY=change-this-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
OPENWEATHER_API_KEY=your-openweather-key
AQICN_API_KEY=your-aqicn-key
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
ENVIRONMENT=development

# Real SMS OTP — pick one: twilio | fast2sms | none
# none = no SMS (dev only returns otp in JSON when ENVIRONMENT=development)
SMS_PROVIDER=none

# Twilio (https://console.twilio.com): trial sends only to verified numbers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Fast2SMS (India): https://www.fast2sms.com — set SMS_PROVIDER=fast2sms
FAST2SMS_API_KEY=
